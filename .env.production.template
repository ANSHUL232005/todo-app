# Production Environment Configuration Template
# Copy this file to .env.production.secure and fill in your values
# WARNING: NEVER commit .env.production.secure to version control!

# ============================================================================
# SECURITY - CRITICAL: Configure these before deployment
# ============================================================================

# JWT Secret Key (minimum 32 characters)
# Generate with: openssl rand -base64 32
# CRITICAL: Keep this secret and never share!
SECRET_KEY=your-secure-secret-key-here-min-32-chars

# Environment type
ENVIRONMENT=production

# Debug mode (MUST be false in production)
DEBUG=false

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# PostgreSQL Connection String
# Format: postgresql://username:password@host:port/dbname
# Host will be: todo-app-db.postgres.database.azure.com
DATABASE_URL=postgresql://todouser:your-strong-password@postgres:5432/tododb

# Optional: SQLite URL (for development only)
# DATABASE_URL=sqlite:///./todo.db

# ============================================================================
# API CONFIGURATION
# ============================================================================

# API binding address (0.0.0.0 for Docker)
API_HOST=0.0.0.0

# API port
API_PORT=8000

# API domain for frontend communication
API_DOMAIN=yourdomain.com

# CORS origins (comma-separated)
# Format: https://domain1.com,https://domain2.com
# WARNING: Using * allows any origin - INSECURE
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ============================================================================
# JWT CONFIGURATION
# ============================================================================

# JWT Algorithm
ALGORITHM=HS256

# Access token expiration (minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Refresh token expiration (days)
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================

# Logging level (debug, info, warning, error, critical)
LOG_LEVEL=info

# Frontend port (for container)
FRONTEND_PORT=3000

# Backend port (for container)
BACKEND_PORT=8000

# ============================================================================
# EMAIL CONFIGURATION (Optional - for notifications)
# ============================================================================

# SMTP Server
SMTP_SERVER=smtp.gmail.com

# SMTP Port
SMTP_PORT=587

# SMTP User (your email)
SMTP_USER=your-email@gmail.com

# SMTP Password (app-specific password for Gmail)
# Generate at: https://myaccount.google.com/apppasswords
SMTP_PASSWORD=your-app-specific-password

# Email from address
EMAIL_FROM=noreply@yourdomain.com

# ============================================================================
# AZURE DEPLOYMENT
# ============================================================================

# Deployment environment
DEPLOYMENT_ENV=azure

# Azure Container Registry Name
CONTAINER_REGISTRY=todoregistry.azurecr.io

# Container Registry Username
CONTAINER_REGISTRY_USERNAME=your-registry-username

# Container Registry Password
CONTAINER_REGISTRY_PASSWORD=your-registry-password

# Resource Group Name
AZURE_RESOURCE_GROUP=todo-rg

# ============================================================================
# DATABASE CREDENTIALS (Azure PostgreSQL)
# ============================================================================

# PostgreSQL Admin Username
POSTGRES_USER=todouser

# PostgreSQL Admin Password (strong password)
# Generate with: openssl rand -base64 16
POSTGRES_PASSWORD=your-secure-postgres-password

# PostgreSQL Database Name
POSTGRES_DB=tododb

# PostgreSQL Password for Application (can be same as POSTGRES_PASSWORD)
# Used in DATABASE_URL connection string
DATABASE_PASSWORD=your-secure-postgres-password

# ============================================================================
# SECURITY HEADERS
# ============================================================================

# HSTS max age (1 year = 31536000)
HSTS_MAX_AGE=31536000

# Rate limiting per second
RATE_LIMIT_PER_SECOND=100

# API rate limiting per second
API_RATE_LIMIT_PER_SECOND=10

# ============================================================================
# BACKUP & MONITORING
# ============================================================================

# Enable automated database backups
BACKUP_ENABLED=true

# Backup frequency (hours)
BACKUP_FREQUENCY=24

# Enable error tracking (e.g., Sentry)
ERROR_TRACKING_ENABLED=false

# Sentry DSN (if error tracking enabled)
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# ============================================================================
# OPTIONAL: ADVANCED CONFIGURATION
# ============================================================================

# Redis URL (for caching/sessions - optional)
# REDIS_URL=redis://localhost:6379/0

# CDN URL (for static assets)
# CDN_URL=https://cdn.yourdomain.com

# Analytics service (e.g., Google Analytics)
# ANALYTICS_KEY=your-analytics-key

# Feature flags
FEATURE_EMAIL_NOTIFICATIONS=true
FEATURE_USER_EXPORT=true
FEATURE_TODO_SHARING=false

# ============================================================================
# TEMPORARY DEPLOYMENT VARIABLES
# ============================================================================

# These are used during deployment only
HOST=0.0.0.0
PORT=8000

# Docker Compose specific
COMPOSE_PROJECT_NAME=todo-app-prod
POSTGRES_INITDB_ARGS=-c max_connections=100

# ============================================================================
# CONFIGURATION NOTES
# ============================================================================

# 1. NEVER share this file - it contains secrets
# 2. Keep separate .env files for development, staging, production
# 3. Rotate POSTGRES_PASSWORD regularly (monthly/quarterly)
# 4. Use Azure Key Vault for production secrets instead of env files
# 5. Enable multi-factor authentication on all admin accounts
# 6. Review logs regularly for security issues
# 7. Update dependencies monthly
# 8. Monitor PostgreSQL backups are running correctly
# 9. Test SSL certificate renewal before expiration
# 10. Document all configuration changes

# ============================================================================
# COMMON ISSUES
# ============================================================================

# Issue: 503 Service Unavailable
# Solution: Check DATABASE_URL is correct, verify PostgreSQL is running

# Issue: 401 Unauthorized on API calls
# Solution: Verify SECRET_KEY is correct and consistent across deployments

# Issue: CORS errors in browser
# Solution: Verify API_DOMAIN and CORS_ORIGINS match your domain

# Issue: SSL certificate error
# Solution: Check certificate is valid and not expired, verify DNS name matches

# Issue: High memory usage
# Solution: Reduce DATABASE_URL connection pool size, increase container memory
